<div class="d35e-pacs-local-armor-settings">
  <p class="notes">
    These choices only matter when <strong>Called shots use local armor piece AC</strong> is enabled.
    Missing or newly added locations default to enabled.
  </p>

  <h3>{{profileLabel}}</h3>
  <section class="d35e-pacs-local-armor-locations">
    {{#each locations}}
      <label class="d35e-pacs-checkbox d35e-pacs-local-armor-location">
        <input type="checkbox" name="location.{{id}}.enabled" {{#if enabled}}checked{{/if}}>
        <span>
          <strong>{{label}}</strong>
          <code>{{id}}</code>
          {{#if coverageSlot}}<small>Coverage: {{coverageSlot}}</small>{{/if}}
        </span>
      </label>
    {{/each}}
  </section>

  <footer class="d35e-pacs-editor-actions">
    <button type="submit"><i class="fas fa-save"></i> Save</button>
  </footer>
</div>
